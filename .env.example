# HubSpot Authentication
# Create a private app in HubSpot: Settings > Integrations > Private Apps
# Copy the access token here
HUBSPOT_PRIVATE_APP_TOKEN=pat-na1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# HubSpot Webhook Security
# Get this from HubSpot when creating the webhook subscription
# Settings > Integrations > Private Apps > [Your App] > Webhooks
HUBSPOT_WEBHOOK_SECRET=your-webhook-secret-from-hubspot

# Configuration
# Must match the exact plural label of your custom Property object in HubSpot
PROPERTY_OBJECT_PLURAL_LABEL=Properties

# How far back to look for activities (in milliseconds)
# Default: 600000 (10 minutes)
LOOKBACK_MS=600000

# Maximum number of activity IDs to fetch per type
# Default: 50
MAX_ACTIVITY_IDS_PER_TYPE=50

# Server Configuration
# Port for the Express server (Railway will set this automatically)
PORT=3000

# Environment (development or production)
NODE_ENV=production
